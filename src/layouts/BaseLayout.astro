---
import '../styles/global.css';
import { env } from 'cloudflare:workers';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "osiri cooperation - ポータルサイト" } = Astro.props;

// 配信元のチャンネルIDを取得
const CHANNEL_ID = (env as any)?.PUBLIC_YOUTUBE_CHANNEL_ID || import.meta.env.PUBLIC_YOUTUBE_CHANNEL_ID || "YOUR_CHANNEL_ID";
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/logo.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | osiri.co</title>
    <meta property="og:title" content={`${title} | osiri.co`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    <ClientRouter />
  </head>
  <body>
    <header class="main-header">
      <nav class="nav-content">
        <a href="/" class="logo">
          <span class="osirico">osiri.co</span>
        </a>
        <div class="nav-group-right">
          <ul class="nav-links">
            <li><a href="/apps/web">WEB APPS</a></li>
            <li><a href="/apps/windows">WINDOWS APPS</a></li>
          </ul>
          <div class="social-links">
            <a href={`https://youtube.com/channel/${CHANNEL_ID}`} target="_blank" rel="noopener noreferrer" class="social-icon-link yt" aria-label="YouTube">
              <svg class="social-icon" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
                <path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"></path>
              </svg>
            </a>
            <a href="https://x.com/choroco119" target="_blank" rel="noopener noreferrer" class="social-icon-link" aria-label="X (Twitter)">
              <svg class="social-icon" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
                <path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932 6.064-6.932zm-1.294 19.497h2.039L6.486 3.24H4.298l13.31 17.41z"></path>
              </svg>
            </a>
          </div>
        </div>
      </nav>
    </header>

    <main class="container" transition:animate="fade">
      <slot />
    </main>

    <footer class="container main-footer">
      <p>&copy; 2026 osiri cooperation. Built with Astro & Premium Research.</p>
    </footer>

    <style>
      .main-header {
        position: sticky;
        top: 0;
        z-index: 1000;
        margin-bottom: 40px;
        background: rgba(15, 16, 20, 0.95);
        border-bottom: 1px solid var(--border-color);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
      }

      .nav-content {
        max-width: 1200px;
        margin: 0 auto;
        height: 66px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0px 40px;
        width: 100%;
      }

      .logo {
        font-size: 1.5rem;
        font-weight: 700;
        letter-spacing: -0.025em;
        background: linear-gradient(135deg, #00aaff 0%, #818cf8 100%);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        display: flex;
        gap: 0.2rem;
      }

      .nav-links {
        display: flex;
        gap: 24px;
        list-style: none;
      }

      .nav-links a {
        font-size: 0.85rem;
        font-weight: 700;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        transition: color 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        height: 100%;
      }

      .nav-links a:hover {
        color: var(--accent);
      }

      @keyframes live-blink {
        0%, 100% {
          opacity: 1;
          transform: scale(1);
        }
        50% {
          opacity: 0.4;
          transform: scale(0.9);
        }
      }

      .nav-group-right {
        display: flex;
        align-items: center;
        gap: 32px;
      }

      .social-links {
        display: flex;
        align-items: center;
        gap: 16px;
        padding-left: 24px;
        border-left: 1px solid rgba(255, 255, 255, 0.1);
      }

      .social-icon-link {
        color: var(--text-secondary);
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .social-icon {
        width: 1.2rem;
        height: 1.2rem;
      }

      .social-icon-link:hover {
        color: #fff;
        transform: translateY(-2px);
      }

      .social-icon-link.yt:hover {
        color: #ff0000;
        filter: drop-shadow(0 0 8px rgba(255, 0, 0, 0.5));
      }

      .social-icon-link:not(.yt):hover {
        filter: drop-shadow(0 0 8px var(--accent-glow));
      }

      .main-footer {
        margin-top: 80px;
        padding-top: 40px;
        padding-bottom: 40px;
        border-top: 1px solid var(--border-color);
        text-align: center;
        color: var(--text-secondary);
        font-size: 0.75rem;
        letter-spacing: 0.05em;
      }

      /* Mobile Styles */
      @media (max-width: 768px) {
        .nav-content {
          padding: 0 16px;
          height: auto;
          min-height: 66px;
          flex-wrap: wrap; /* 小さい画面で入り切らない場合、安全に折り返す */
          justify-content: center;
          gap: 8px;
          padding-top: 12px;
          padding-bottom: 12px;
        }

        .nav-group-right {
          gap: 16px;
          width: 100%;
          justify-content: center;
        }

        .nav-links {
          gap: 12px;
        }

        .nav-links a {
          font-size: 0.7rem;
        }

        .social-links {
          padding-left: 12px;
          gap: 12px;
        }
      }

      /* Super Small screens */
      @media (max-width: 480px) {
        .nav-links {
          margin-bottom: 8px;
        }
        .social-links {
          border-left: none;
          padding-left: 0;
          margin-top: 4px;
        }
      }
    </style>
  </body>
</html>
