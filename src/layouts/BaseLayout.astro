---
import '../styles/global.css';
import { env } from 'cloudflare:workers';
import { getLiveStatus } from '../lib/youtube';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "osiri cooperation - ポータルサイト" } = Astro.props;

// 配信状態の取得
const CHANNEL_ID = (env as any)?.PUBLIC_YOUTUBE_CHANNEL_ID || import.meta.env.PUBLIC_YOUTUBE_CHANNEL_ID || "YOUR_CHANNEL_ID";
const MANUALLY_SET_VIDEO_ID = (env as any)?.PUBLIC_CURRENT_LIVE_ID || import.meta.env.PUBLIC_CURRENT_LIVE_ID;
const { isLive, title: liveTitle } = await getLiveStatus(CHANNEL_ID, MANUALLY_SET_VIDEO_ID);

// サイト全体に共有キャッシュを設定 (3分間)
Astro.response.headers.set('Cache-Control', 'public, s-maxage=180, stale-while-revalidate=600');
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/logo.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | osiri.co</title>
    <meta property="og:title" content={`${title} | osiri.co`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    <ClientRouter />
  </head>
  <body>
    <header class="main-header">
      <nav class="nav-content">
        <a href="/" class="logo">
          <span class="osirico">osiri.co</span>
        </a>
        <ul class="nav-links">
          <li>
            <a href="/live" class="nav-live-link">
              <span class="nav-live-label">LIVE</span>
              {isLive && (
                <>
                  <span class="live-indicator" aria-hidden="true"></span>
                  {liveTitle && <span class="live-title">{liveTitle}</span>}
                </>
              )}
            </a>
          </li>
          <li><a href="/apps/web">WEB APPS</a></li>
          <li><a href="/apps/windows">WINDOWS APPS</a></li>
        </ul>
      </nav>
    </header>

    <main class="container" transition:animate="fade">
      <slot />
    </main>

    <footer class="container main-footer">
      <p>&copy; 2026 osiri cooperation. Built with Astro & Premium Research.</p>
    </footer>

    <style>
      .main-header {
        position: sticky;
        top: 0;
        z-index: 1000;
        margin-bottom: 40px;
        background: rgba(15, 16, 20, 0.95);
        border-bottom: 1px solid var(--border-color);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
      }

      .nav-content {
        height: 66px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0px 40px; /* 画面端のパディング */
        width: 100%;
      }

      .logo {
        font-size: 1.5rem;
        font-weight: 700;
        letter-spacing: -0.025em;
        background: linear-gradient(135deg, #00aaff 0%, #818cf8 100%);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        display: flex;
        gap: 0.2rem;
      }

      .nav-links {
        display: flex;
        gap: 24px;
        list-style: none;
      }

      .nav-links a {
        font-size: 0.85rem;
        font-weight: 700;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        transition: color 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        height: 100%;
      }

      .nav-links a:hover {
        color: var(--accent);
      }

      .live-indicator {
        width: 8px;
        height: 8px;
        background-color: #ff4b2b;
        border-radius: 50%;
        box-shadow: 0 0 10px rgba(255, 75, 43, 0.5);
        animation: live-blink 2s infinite;
        /* ドットの位置を視覚的に文字の高さに合わせる調整 */
        margin-top: 1px;
        margin-right: 4px;
      }

      .live-title {
        font-size: 0.7rem;
        font-weight: 400;
        color: var(--text-secondary);
        opacity: 0.7;
        max-width: 250px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        border-left: 1px solid rgba(255, 255, 255, 0.1);
        padding-left: 10px;
        margin-left: 6px;
        letter-spacing: 0.02em;
        text-transform: none; /* タイトルは等倍で表示 */
      }

      @keyframes live-blink {
        0%, 100% {
          opacity: 1;
          transform: scale(1);
        }
        50% {
          opacity: 0.4;
          transform: scale(0.9);
        }
      }

      .main-footer {
        margin-top: 80px;
        padding-top: 40px;
        padding-bottom: 40px;
        border-top: 1px solid var(--border-color);
        text-align: center;
        color: var(--text-secondary);
        font-size: 0.75rem;
        letter-spacing: 0.05em;
      }
    </style>
  </body>
</html>
