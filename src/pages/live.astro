---
import BaseLayout from '../layouts/BaseLayout.astro';
import { env } from 'cloudflare:workers';
import { getLiveStatus } from '../lib/youtube';

// 環境変数の取得 (Astro 6 Cloudflare Adapter 対応)
const CHANNEL_ID = (env as any).PUBLIC_YOUTUBE_CHANNEL_ID || import.meta.env.PUBLIC_YOUTUBE_CHANNEL_ID || "YOUR_CHANNEL_ID";
const MANUALLY_SET_VIDEO_ID = (env as any).PUBLIC_CURRENT_LIVE_ID || import.meta.env.PUBLIC_CURRENT_LIVE_ID;

// 共通ライブラリを使用して配信状態を取得
const { isLive, videoId } = await getLiveStatus(CHANNEL_ID, MANUALLY_SET_VIDEO_ID);

// 共有キャッシュの設定 (3分間 CDN に保存し、裏側でさらに最大10分間再検証を許容)
Astro.response.headers.set('Cache-Control', 'public, s-maxage=180, stale-while-revalidate=600');

// 最終的なプレイヤー URL
const embedUrl = videoId 
  ? `https://www.youtube.com/embed/${videoId}?autoplay=1&mute=0`
  : `https://www.youtube.com/embed/live_stream?channel=${CHANNEL_ID}`;
---

<BaseLayout title="LIVE">
  <div class="streaming-container">
    <div class="status-header glass-panel">
      <div class="status-icon">📺</div>
      <div class="status-info">
        <div class="status-indicator">
          <span class={`dot ${isLive ? 'live' : 'offline'}`}></span>
          <span class="status-text">{isLive ? 'ON AIR' : 'OFFLINE'}</span>
        </div>
        <h2 class="stream-title">
          {isLive ? 'Currently Streaming' : 'Live Stream Status (Auto-Follow)'}
        </h2>
      </div>
    </div>

    <div class={`video-grid ${videoId ? 'has-chat' : 'no-chat'}`}>
      <div class="video-wrapper glass-panel">
        <iframe
          width="100%"
          height="100%"
          src={embedUrl}
          title="YouTube video player"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen></iframe>
      </div>

      {videoId && (
        <div class="chat-wrapper glass-panel">
          <div class="chat-header">LIVE CHAT</div>
          <iframe
            width="100%"
            height="100%"
            src={`https://www.youtube.com/live_chat?v=${videoId}&embed_domain=${Astro.url.hostname}`}
          ></iframe>
        </div>
      )}
    </div>

    {!isLive && !videoId && (
      <div class="offline-placeholder glass-panel flex-center">
        <div class="offline-content">
          <div class="offline-icon">📡</div>
          <h3>現在は配信外です</h3>
          <p>配信は不定期に行われます。最新の活動状況や告知は YouTube チャンネルをご確認ください。</p>
          <div class="offline-links">
            <a href={`https://www.youtube.com/channel/${CHANNEL_ID}`} class="btn-glow">YouTube チャンネルへ</a>
          </div>
        </div>
      </div>
    )}
  </div>

  <style is:global>
    /* LIVEページのみコンテナ幅を大幅に拡張 */
    main.container {
      max-width: 3840px !important;
      width: 95% !important;
      padding: 0 20px;
    }
  </style>

  <style>
    .streaming-container {
      display: flex;
      flex-direction: column;
      gap: 24px;
      margin-bottom: 60px;
    }

    .status-header {
      padding: 24px 32px;
      display: flex;
      align-items: center;
      gap: 32px;
      border-left: 4px solid var(--accent);
    }

    .status-icon {
      font-size: 3.5rem;
      flex-shrink: 0;
    }

    .status-info {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .status-indicator {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 6px 12px;
      background: rgba(0, 0, 0, 0.4);
      border-radius: 20px;
      font-weight: 700;
      font-size: 0.75rem;
      letter-spacing: 0.1em;
    }

    .dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
    }

    .dot.live {
      background-color: #ff4b2b;
      box-shadow: 0 0 10px #ff4b2b;
      animation: blink 2s infinite;
    }

    .dot.offline {
      background-color: #444;
    }

    @keyframes blink {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.4; }
    }

    .stream-title {
      font-size: 1.1rem;
      color: #fff;
    }

    .video-grid {
      display: grid;
      gap: 24px;
      height: auto;
    }

    .video-grid.has-chat {
      grid-template-columns: 1fr 380px;
    }

    .video-grid.no-chat {
      grid-template-columns: 1fr;
    }

    .video-wrapper {
      padding: 0;
      overflow: hidden;
      aspect-ratio: 16/9;
      background: #000;
      width: 100%;
    }

    .chat-wrapper {
      display: flex;
      flex-direction: column;
      overflow: hidden;
      background: rgba(15, 16, 20, 0.95);
      height: auto;
    }

    .chat-header {
      padding: 10px;
      background: rgba(255, 255, 255, 0.05);
      font-size: 0.7rem;
      font-weight: 700;
      text-align: center;
      border-bottom: 1px solid var(--border-color);
      color: var(--accent);
      letter-spacing: 0.1em;
    }

    .offline-placeholder {
      min-height: 250px;
      padding: 40px;
      text-align: center;
      margin-top: 24px;
    }

    .offline-icon {
      font-size: 3rem;
      margin-bottom: 20px;
      opacity: 0.3;
    }

    .offline-placeholder h3 {
      font-size: 1.4rem;
      margin-bottom: 16px;
      color: #fff;
    }

    .offline-placeholder p {
      color: var(--text-secondary);
      max-width: 500px;
      margin: 0 auto 32px;
    }

    .btn-glow {
      padding: 10px 28px;
      background: var(--accent);
      color: #fff;
      border-radius: 6px;
      font-weight: 700;
      transition: all 0.2s;
      box-shadow: 0 4px 15px rgba(0, 170, 255, 0.3);
      font-size: 0.9rem;
    }

    .btn-glow:hover {
      box-shadow: 0 0 20px var(--accent-glow);
      transform: translateY(-2px);
    }

    @media (max-width: 1400px) {
      .video-grid.has-chat {
        grid-template-columns: 1fr 320px;
        gap: 16px;
      }
    }

    @media (max-width: 992px) {
      .video-grid.has-chat {
        grid-template-columns: 1fr;
      }
      .chat-wrapper {
        height: 500px;
      }
    }
  </style>
</BaseLayout>
