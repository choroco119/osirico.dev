---
import BaseLayout from '../layouts/BaseLayout.astro';

import { env } from 'cloudflare:workers';

// 環境変数の取得 (Astro 6 Cloudflare Adapter 対応)
const CHANNEL_ID = (env as any).PUBLIC_YOUTUBE_CHANNEL_ID || import.meta.env.PUBLIC_YOUTUBE_CHANNEL_ID || "YOUR_CHANNEL_ID";
const API_KEY = (env as any).YOUTUBE_API_KEY || import.meta.env.YOUTUBE_API_KEY;
const MANUALLY_SET_VIDEO_ID = (env as any).PUBLIC_CURRENT_LIVE_ID || import.meta.env.PUBLIC_CURRENT_LIVE_ID;

let isLive = false;
let videoId = MANUALLY_SET_VIDEO_ID || null;
let error = null;

if (API_KEY && !videoId) {
  try {
    const response = await fetch(
      `https://www.googleapis.com/youtube/v3/search?part=snippet&channelId=${CHANNEL_ID}&type=video&eventType=live&key=${API_KEY}`
    );
    const data = await response.json();
    if (data.items && data.items.length > 0) {
      isLive = true;
      videoId = data.items[0].id.videoId;
    }
  } catch (e) {
    error = "Failed to fetch live status.";
  }
} else if (videoId) {
  isLive = true;
}
---

<BaseLayout title="LIVE">
  <div class="streaming-container">
    <div class="status-header glass-panel">
      <div class="status-indicator">
        <span class={`dot ${isLive ? 'live' : 'offline'}`}></span>
        <span class="status-text">{isLive ? 'ON AIR' : 'OFFLINE'}</span>
      </div>
      <h2 class="stream-title">
        {isLive ? 'Currently Streaming' : 'Live Stream Status'}
      </h2>
    </div>

    {isLive ? (
      <div class="video-grid">
        <div class="video-wrapper glass-panel">
          <iframe
            width="100%"
            height="100%"
            src={`https://www.youtube.com/embed/${videoId}?autoplay=1&mute=0`}
            title="YouTube video player"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen></iframe>
        </div>

        <div class="chat-wrapper glass-panel">
          <div class="chat-header">LIVE CHAT</div>
          <iframe
            width="100%"
            height="100%"
            src={`https://www.youtube.com/live_chat?v=${videoId}&embed_domain=${Astro.url.hostname}`}
          ></iframe>
        </div>
      </div>
    ) : (
      <div class="offline-placeholder glass-panel flex-center">
        <div class="offline-content">
          <div class="offline-icon">📡</div>
          <h3>現在オフラインです</h3>
          <p>配信は不定期に行われます。最新の活動状況や告知は YouTube チャンネルをご確認ください。</p>
          <div class="offline-links">
            <a href={`https://www.youtube.com/channel/${CHANNEL_ID}`} class="btn-glow">YouTube チャンネルへ</a>
          </div>
        </div>
      </div>
    )}

  </div>

  <style is:global>
    /* LIVEページのみコンテナ幅を大幅に拡張 */
    main.container {
      max-width: 1800px !important;
      width: 95% !important;
      padding: 0 20px;
    }
  </style>

  <style>
    .streaming-container {
      display: flex;
      flex-direction: column;
      gap: 24px;
      margin-bottom: 60px;
    }

    .status-header {
      padding: 16px 24px;
      display: flex;
      align-items: center;
      gap: 24px;
      border-left: 4px solid var(--accent);
    }

    .status-indicator {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 6px 12px;
      background: rgba(0, 0, 0, 0.4);
      border-radius: 20px;
      font-weight: 700;
      font-size: 0.75rem;
      letter-spacing: 0.1em;
    }

    .dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
    }

    .dot.live {
      background-color: #ff4b2b;
      box-shadow: 0 0 10px #ff4b2b;
      animation: blink 2s infinite;
    }

    .dot.offline {
      background-color: #444;
    }

    @keyframes blink {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.4; }
    }

    .stream-title {
      font-size: 1.1rem;
      color: #fff;
    }

    .video-grid {
      display: grid;
      grid-template-columns: 1fr 380px;
      gap: 24px;
      /* 画面高さに合わせて調整 */
      height: auto;
    }

    .video-wrapper {
      padding: 0;
      overflow: hidden;
      aspect-ratio: 16/9;
      background: #000;
      width: 100%;
    }

    .chat-wrapper {
      display: flex;
      flex-direction: column;
      overflow: hidden;
      background: rgba(15, 16, 20, 0.95);
      height: auto;
    }

    .chat-header {
      padding: 10px;
      background: rgba(255, 255, 255, 0.05);
      font-size: 0.7rem;
      font-weight: 700;
      text-align: center;
      border-bottom: 1px solid var(--border-color);
      color: var(--accent);
      letter-spacing: 0.1em;
    }

    .offline-placeholder {
      min-height: 450px;
      padding: 60px;
      text-align: center;
    }

    .offline-icon {
      font-size: 3rem;
      margin-bottom: 20px;
      opacity: 0.3;
    }

    .offline-placeholder h3 {
      font-size: 1.4rem;
      margin-bottom: 16px;
      color: #fff;
    }

    .offline-placeholder p {
      color: var(--text-secondary);
      max-width: 500px;
      margin: 0 auto 32px;
    }

    .btn-glow {
      padding: 10px 28px;
      background: var(--accent);
      color: #fff;
      border-radius: 6px;
      font-weight: 700;
      transition: all 0.2s;
      box-shadow: 0 4px 15px rgba(0, 170, 255, 0.3);
      font-size: 0.9rem;
    }

    .btn-glow:hover {
      box-shadow: 0 0 20px var(--accent-glow);
      transform: translateY(-2px);
    }

    @media (max-width: 1200px) {
      .video-grid {
        grid-template-columns: 1fr 320px;
        gap: 16px;
      }
    }

    @media (max-width: 992px) {
      .video-grid {
        grid-template-columns: 1fr;
      }
      .chat-wrapper {
        height: 500px;
      }
    }
  </style>
</BaseLayout>
