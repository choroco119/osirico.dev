---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AppCard from '../../../components/AppCard.astro';

const windowsApps = await getCollection('windows-apps');
---

<BaseLayout title="WINDOWS APPS">
  <div class="apps-header">
    <div class="apps-icon-hero">💻</div>
    <h2 class="sub-title">TOOLBOX</h2>
    <h1 class="page-title">Windows Applications</h1>
    <p class="intro">
      デスクトップで動作する専用アプリケーション
    </p>
  </div>

  <div class="apps-grid">
    {windowsApps.map(app => (
      <AppCard app={app} />
    ))}
  </div>

  <style>
    .apps-header {
      margin-bottom: 60px;
      display: grid;
      grid-template-columns: auto 1fr;
      grid-template-rows: auto auto auto;
      column-gap: 40px;
      align-items: center;
      text-align: left;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      padding-bottom: 40px;
    }

    .apps-icon-hero {
      grid-row: 1 / 4;
      font-size: 5rem;
      filter: drop-shadow(0 0 20px var(--accent-glow));
    }

    .sub-title {
      grid-column: 2;
      grid-row: 1;
      font-size: 0.8rem;
      color: var(--accent);
      letter-spacing: 0.3em;
      margin-bottom: 8px;
      font-weight: 700;
    }

    .page-title {
      grid-column: 2;
      grid-row: 2;
      font-size: 3.5rem;
      margin: 0;
      color: #fff;
      font-weight: 800;
    }

    .intro {
      grid-column: 2;
      grid-row: 3;
      color: var(--text-secondary);
      max-width: 600px;
      margin: 8px 0 0 0;
      line-height: 1.7;
    }

    .apps-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
      gap: 32px;
    }
  </style>
</BaseLayout>
